<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>شراء كروت - محفظة المفيد نت</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Tahoma', sans-serif; }
        body {
            background: linear-gradient(145deg, #0b1120, #19233c);
            min-height: 100vh;
            padding: 20px;
        }
        .container { max-width: 600px; margin: 0 auto; }
        .header {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
            padding: 20px;
            border-radius: 30px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .balance-card {
            background: rgba(20, 30, 50, 0.9);
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 30px;
            padding: 20px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .balance-amount {
            font-size: 28px;
            font-weight: bold;
            color: #d4af37;
        }
        .cards-grid { display: grid; gap: 15px; margin-bottom: 20px; }
        .card-item {
            background: rgba(20, 30, 50, 0.9);
            border: 2px solid rgba(212, 175, 55, 0.3);
            border-radius: 20px;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        .card-item:hover { transform: translateY(-3px); border-color: #d4af37; }
        .card-item.selected { border-color: #d4af37; background: rgba(212, 175, 55, 0.1); }
        .card-price { font-size: 24px; font-weight: bold; color: #d4af37; }
        .buy-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            border: none;
            border-radius: 30px;
            color: white;
            font-weight: bold;
            font-size: 18px;
            cursor: pointer;
        }
        .buy-btn:disabled { background: #555; cursor: not-allowed; }
        .error, .success {
            padding: 12px;
            border-radius: 30px;
            margin-bottom: 20px;
            text-align: center;
        }
        .error { background: rgba(220,53,69,0.2); color: #ff9b9b; }
        .success { background: rgba(46,204,113,0.2); color: #2ecc71; }
        .back-btn {
            background: rgba(255,255,255,0.2);
            padding: 8px 20px;
            border-radius: 50px;
            text-decoration: none;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🛒 متجر الكروت</h1>
            <a href="/dashboard" class="back-btn">← رجوع</a>
        </div>
        
        <div class="balance-card">
            <div>
                <div style="color: #aaa;">رصيدك الحالي</div>
                <div class="balance-amount"><%= balance %> ريال</div>
            </div>
            <div style="font-size: 40px;">💰</div>
        </div>
        
        <div id="errorMsg" class="error" style="display: none;"></div>
        <div id="successMsg" class="success" style="display: none;"></div>
        
        <div class="cards-grid" id="cardsGrid">
            <% const cards = [
                {name: 'كرت 200', price: 200, type: '200', icon: '💳', color: '#27ae60'},
                {name: 'كرت 300', price: 300, type: '300', icon: '💳', color: '#2980b9'},
                {name: 'كرت 500', price: 500, type: '500', icon: '💳', color: '#8e44ad'},
                {name: 'كرت 1000', price: 1000, type: '1000', icon: '💎', color: '#f39c12'},
                {name: 'كرت 3000', price: 3000, type: '3000', icon: '👑', color: '#e67e22'}
            ]; %>
            <% cards.forEach(card => { %>
            <div class="card-item" data-name="<%= card.name %>" data-price="<%= card.price %>" data-type="<%= card.type %>">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <div style="width: 50px; height: 50px; background: <%= card.color %>; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 24px;"><%= card.icon %></div>
                    <div>
                        <h3><%= card.name %></h3>
                        <p style="color: #aaa;">كرت رصيد <%= card.price %> ريال</p>
                    </div>
                </div>
                <div class="card-price"><%= card.price %> <small>ريال</small></div>
            </div>
            <% }); %>
        </div>
        
        <button id="buyBtn" class="buy-btn" disabled>🔒 اختر كرت أولاً</button>
    </div>
    
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        let selectedCard = null;
        let userId = null;
        
        // الحصول على userId من الجلسة
        fetch('/dashboard')
            .then(res => res.text())
            .then(html => {
                const match = html.match(/userId = (\d+)/);
                if (match) userId = match[1];
                if (userId) socket.emit('register-user', userId);
            });
        
        // اختيار الكرت
        document.querySelectorAll('.card-item').forEach(card => {
            card.addEventListener('click', () => {
                document.querySelectorAll('.card-item').forEach(c => c.classList.remove('selected'));
                card.classList.add('selected');
                selectedCard = {
                    name: card.dataset.name,
                    price: parseInt(card.dataset.price),
                    type: card.dataset.type
                };
                document.getElementById('buyBtn').disabled = false;
                document.getElementById('buyBtn').innerHTML = `✅ تأكيد شراء ${selectedCard.name}`;
            });
        });
        
        // شراء
        document.getElementById('buyBtn').addEventListener('click', async () => {
            if (!selectedCard) return;
            
            const errorDiv = document.getElementById('errorMsg');
            const successDiv = document.getElementById('successMsg');
            errorDiv.style.display = 'none';
            successDiv.style.display = 'none';
            
            const response = await fetch('/api/buy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    userId: userId,
                    card_name: selectedCard.name,
                    price: selectedCard.price,
                    card_type: selectedCard.type
                })
            });
            
            const data = await response.json();
            
            if (data.error) {
                errorDiv.textContent = data.error;
                errorDiv.style.display = 'block';
            } else if (data.success) {
                successDiv.textContent = '✅ تم الشراء بنجاح! جاري تحويلك لعرض الكرت...';
                successDiv.style.display = 'block';
                setTimeout(() => {
                    window.location.href = `/display_card?code=${data.voucherCode}&amount=${data.cardType}`;
                }, 2000);
            }
        });
        
        // استقبال إشعارات
        socket.on('notification', (data) => {
            const successDiv = document.getElementById('successMsg');
            successDiv.textContent = data.message;
            successDiv.style.display = 'block';
            setTimeout(() => successDiv.style.display = 'none', 5000);
        });
    </script>
</body>
</html>